# Playwright MCP Server Docker Compose Configuration
# This file provides Docker orchestration for the Playwright MCP server and its dependencies

version: '3.8'

services:
  # Playwright MCP Server
  playwright-mcp:
    build:
      context: ./backend
      dockerfile: Dockerfile.playwright
      args:
        - ENVIRONMENT=production
        - PLAYWRIGHT_VERSION=${PLAYWRIGHT_VERSION:-1.40.0}
    container_name: playwright-mcp-server
    ports:
      - "${PLAYWRIGHT_PORT:-8004}:8004"
    environment:
      # Server Configuration
      - ENVIRONMENT=production
      - HOST=0.0.0.0
      - PORT=8004
      - WORKERS=4
      - TIMEOUT=300
      
      # Database Configuration
      - DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
      
      # Redis Configuration
      - REDIS_URL=redis://redis:6379/8
      - REDIS_PASSWORD=${REDIS_PASSWORD}
      
      # Security Configuration
      - SECRET_KEY=${SECRET_KEY}
      - JWT_SECRET_KEY=${JWT_SECRET_KEY}
      - JWT_ALGORITHM=HS256
      - JWT_EXPIRE_MINUTES=60
      - API_KEY_REQUIRED=true
      - ADMIN_API_KEY_REQUIRED=true
      
      # Playwright Configuration
      - PLAYWRIGHT_BROWSER_TYPE=chromium
      - PLAYWRIGHT_HEADLESS=true
      - PLAYWRIGHT_TIMEOUT=30000
      - PLAYWRIGHT_VIEWPORT_WIDTH=1280
      - PLAYWRIGHT_VIEWPORT_HEIGHT=720
      - PLAYWRIGHT_AUTO_WAIT_TIMEOUT=30000
      - PLAYWRIGHT_ACTION_TIMEOUT=10000
      
      # Browser Pool Configuration
      - PLAYWRIGHT_POOL_SIZE=5
      - PLAYWRIGHT_POOL_TIMEOUT=60000
      - PLAYWRIGHT_MAX_CONCURRENT_SESSIONS=10
      - PLAYWRIGHT_MAX_SESSION_DURATION=3600
      - PLAYWRIGHT_MAX_MEMORY_PER_SESSION=256
      - PLAYWRIGHT_MAX_CPU_PER_SESSION=0.5
      
      # Resource Management
      - PLAYWRIGHT_MEMORY_THRESHOLD_MB=512
      - PLAYWRIGHT_CPU_THRESHOLD_PERCENT=80
      - PLAYWRIGHT_MEMORY_CLEANUP_INTERVAL=300
      
      # Security Settings
      - PLAYWRIGHT_ENABLE_VIDEO_RECORDING=false
      - PLAYWRIGHT_ENABLE_SCREENSHOT_CAPTURE=true
      - PLAYWRIGHT_ENABLE_DOWNLOADS=false
      - PLAYWRIGHT_DOWNLOAD_DIR=/tmp/playwright_downloads
      - PLAYWRIGHT_TEMP_DIR=/tmp/playwright_temp
      
      # Artifact Storage
      - PLAYWRIGHT_STORAGE_BACKEND=local
      - PLAYWRIGHT_STORAGE_PATH=/app/data/playwright/artifacts
      - PLAYWRIGHT_MAX_ARTIFACT_SIZE=100
      - PLAYWRIGHT_ARTIFACT_RETENTION_DAYS=30
      - PLAYWRIGHT_ENABLE_VIDEO=false
      - PLAYWRIGHT_ENABLE_SCREENSHOT=true
      - PLAYWRIGHT_ENABLE_PDF=false
      - PLAYWRIGHT_ENABLE_TRACE=true
      
      # Screenshot Configuration
      - PLAYWRIGHT_SCREENSHOT_ENABLED=true
      - PLAYWRIGHT_SCREENSHOT_FORMAT=png
      - PLAYWRIGHT_SCREENSHOT_FULL_PAGE=false
      - PLAYWRIGHT_SCREENSHOT_QUALITY=90
      
      # Trace Configuration
      - PLAYWRIGHT_TRACE_ENABLED=true
      - PLAYWRIGHT_TRACE_FORMAT=zip
      - PLAYWRIGHT_TRACE_SCREENSHOTS=true
      - PLAYWRIGHT_TRACE_SNAPSHOTS=true
      - PLAYWRIGHT_TRACE_SOURCES=true
      
      # Monitoring Configuration
      - PLAYWRIGHT_HEALTH_CHECK_ENABLED=true
      - PLAYWRIGHT_HEALTH_CHECK_ENDPOINT=/health
      - PLAYWRIGHT_METRICS_ENABLED=true
      - PLAYWRIGHT_METRICS_ENDPOINT=/metrics
      - PLAYWRIGHT_METRICS_PORT=9090
      - PLAYWRIGHT_PERFORMANCE_METRICS_ENABLED=true
      - PLAYWRIGHT_PERFORMANCE_METRICS_INTERVAL=5000
      
      # Logging Configuration
      - LOG_LEVEL=INFO
      - LOG_FORMAT=json
      - PLAYWRIGHT_FILE_LOG_PATH=/app/logs/playwright/server.log
      - PLAYWRIGHT_FILE_LOG_MAX_SIZE=100
      - PLAYWRIGHT_FILE_LOG_BACKUP_COUNT=10
      - PLAYWRIGHT_ENABLE_CONSOLE_LOGS=true
      - PLAYWRIGHT_ENABLE_NETWORK_LOGS=false
      - PLAYWRIGHT_LOG_RETENTION_DAYS=7
      
      # HTTP Configuration
      - PLAYWRIGHT_POOL_CONNECTIONS=10
      - PLAYWRIGHT_POOL_MAXSIZE=20
      - PLAYWRIGHT_POOL_STALE=10
      - PLAYWRIGHT_TIMEOUT=30
      - PLAYWRIGHT_MAX_RETRIES=3
      - PLAYWRIGHT_BACKOFF_FACTOR=0.3
      
      # Cleanup Configuration
      - PLAYWRIGHT_CLEANUP_INTERVAL=3600
      - PLAYWRIGHT_MAX_SESSION_IDLE_TIME=1800
      - PLAYWRIGHT_ENABLE_AUTO_CLEANUP=true
      - PLAYWRIGHT_LOG_RETENTION_DAYS=7
      - PLAYWRIGHT_ARTIFACT_RETENTION_DAYS=30
      
      # Backup Configuration
      - PLAYWRIGHT_BACKUP_ENABLED=true
      - PLAYWRIGHT_BACKUP_INTERVAL=86400
      - PLAYWRIGHT_BACKUP_RETENTION_DAYS=30
      - PLAYWRIGHT_BACKUP_LOCATION=/app/backups/playwright
      - PLAYWRIGHT_RECOVERY_ENABLED=true
      - PLAYWRIGHT_AUTO_RECOVERY=true
      - PLAYWRIGHT_RECOVERY_MAX_ATTEMPTS=3
      - PLAYWRIGHT_RECOVERY_BACKOFF_SECONDS=60
      
      # Security Headers
      - PLAYWRIGHT_ENABLE_CORS=true
      - PLAYWRIGHT_ENABLE_RATE_LIMITING=true
      - PLAYWRIGHT_RATE_LIMIT_REQUESTS=100
      - PLAYWRIGHT_RATE_LIMIT_WINDOW=60
      - PLAYWRIGHT_SECURITY_HEADERS_ENABLED=true
      
      # Feature Flags
      - PLAYWRIGHT_ADVANCED_SELECTORS=true
      - PLAYWRIGHT_SMART_WAITING=true
      - PLAYWRIGHT_AUTO_RETRY=true
      - PLAYWRIGHT_PERFORMANCE_MONITORING=true
      - PLAYWRIGHT_DEVICE_EMULATION=true
      - PLAYWRIGHT_GEOLOCATION=true
      
      # Browser Options
      - PLAYWRIGHT_CHROMIUM_OPTIONS="--no-sandbox,--disable-dev-shm-usage,--disable-web-security,--disable-setuid-sandbox,--disable-gpu,--no-first-run,--no-zygote,--single-process"
      
    volumes:
      # Data directories
      - playwright_data:/app/data/playwright
      - playwright_logs:/app/logs/playwright
      - playwright_backups:/app/backups/playwright
      - playwright_profiles:/app/data/playwright/profiles
      - playwright_artifacts:/app/data/playwright/artifacts
      - playwright_temp:/tmp/playwright_temp
      - playwright_downloads:/tmp/playwright_downloads
      
      # Configuration
      - ./backend/config/playwright.toml:/app/config/playwright.toml:ro
      
      # Development mode only
      - ./backend:/app:ro
      - playwright_node_modules:/app/node_modules
      
    networks:
      - chronos-network
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8004/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 40s
    deploy:
      resources:
        limits:
          memory: 1G
          cpus: '0.5'
        reservations:
          memory: 512M
          cpus: '0.25'
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy

  # Playwright MCP Server (Development)
  playwright-mcp-dev:
    build:
      context: ./backend
      dockerfile: Dockerfile.playwright
      args:
        - ENVIRONMENT=development
        - PLAYWRIGHT_VERSION=${PLAYWRIGHT_VERSION:-1.40.0}
    container_name: playwright-mcp-dev
    ports:
      - "${PLAYWRIGHT_DEV_PORT:-8005}:8004"
    environment:
      # Development Configuration
      - ENVIRONMENT=development
      - HOST=0.0.0.0
      - PORT=8004
      - DEBUG_MODE=true
      - DEV_SERVER=true
      - HOT_RELOAD=true
      - TEST_MODE=false
      - TEST_TIMEOUT=30000
      - LOG_LEVEL=DEBUG
      - LOG_FORMAT=text
      - PLAYWRIGHT_ENABLE_CONSOLE_LOGS=true
      - PLAYWRIGHT_ENABLE_NETWORK_LOGS=true
      - PLAYWRIGHT_BROWSER_TYPE=chromium
      - PLAYWRIGHT_HEADLESS=false  # Allow browser visibility in dev
      - PLAYWRIGHT_VIEWPORT_WIDTH=1280
      - PLAYWRIGHT_VIEWPORT_HEIGHT=720
      - PLAYWRIGHT_POOL_SIZE=2  # Smaller pool for dev
      - PLAYWRIGHT_MAX_CONCURRENT_SESSIONS=5
      - PLAYWRIGHT_MAX_SESSION_DURATION=1800  # 30 min
      - DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
      - REDIS_URL=redis://redis:6379/8
      - SECRET_KEY=${SECRET_KEY}
      - JWT_SECRET_KEY=${JWT_SECRET_KEY}
    volumes:
      # Mount source for development
      - ./backend:/app
      - playwright_dev_data:/app/data/playwright
      - playwright_dev_logs:/app/logs/playwright
      - playwright_dev_profiles:/app/data/playwright/profiles
      - ./backend/config/playwright.toml:/app/config/playwright.toml:ro
    networks:
      - chronos-network
    profiles:
      - development
    restart: unless-stopped
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy

  # PostgreSQL Database (for Playwright data)
  postgres:
    image: postgres:15-alpine
    container_name: postgres-playwright
    environment:
      - POSTGRES_DB=${POSTGRES_DB}
      - POSTGRES_USER=${POSTGRES_USER}
      - POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
      - POSTGRES_INITDB_ARGS=--encoding=UTF-8 --lc-collate=en_US.UTF-8 --lc-ctype=en_US.UTF-8
    ports:
      - "${POSTGRES_PORT:-5432}:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
      - postgres_logs:/var/log/postgresql
      - ./backend/init-db:/docker-entrypoint-initdb.d:ro
    networks:
      - chronos-network
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER} -d ${POSTGRES_DB}"]
      interval: 10s
      timeout: 5s
      retries: 5

  # Redis Cache (for Playwright sessions and artifacts)
  redis:
    image: redis:7-alpine
    container_name: redis-playwright
    command: >
      redis-server
      --requirepass ${REDIS_PASSWORD}
      --appendonly yes
      --appendfsync everysec
      --maxmemory 512mb
      --maxmemory-policy allkeys-lru
    ports:
      - "${REDIS_PORT:-6379}:6379"
    volumes:
      - redis_data:/data
      - redis_logs:/var/log/redis
    networks:
      - chronos-network
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "redis-cli", "-a", "${REDIS_PASSWORD}", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5

  # MinIO Object Storage (for artifacts)
  minio:
    image: minio/minio:latest
    container_name: minio-playwright
    ports:
      - "${MINIO_PORT:-9000}:9000"
      - "${MINIO_CONSOLE_PORT:-9001}:9001"
    environment:
      - MINIO_ROOT_USER=${MINIO_ACCESS_KEY}
      - MINIO_ROOT_PASSWORD=${MINIO_SECRET_KEY}
      - MINIO_REGION_NAME=${MINIO_REGION:-us-east-1}
    volumes:
      - minio_data:/data
      - minio_logs:/var/log/minio
    command: server /data --console-address ":9001"
    networks:
      - chronos-network
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:9000/minio/health/live"]
      interval: 30s
      timeout: 20s
      retries: 3

  # Nginx Reverse Proxy (for production)
  nginx:
    image: nginx:alpine
    container_name: nginx-playwright
    ports:
      - "${NGINX_HTTP_PORT:-80}:80"
      - "${NGINX_HTTPS_PORT:-443}:443"
    volumes:
      - ./nginx/nginx.conf:/etc/nginx/nginx.conf:ro
      - ./nginx/conf.d/playwright.conf:/etc/nginx/conf.d/playwright.conf:ro
      - ./nginx/ssl:/etc/nginx/ssl:ro
      - nginx_logs:/var/log/nginx
    networks:
      - chronos-network
    restart: unless-stopped
    depends_on:
      - playwright-mcp
    profiles:
      - production

  # Prometheus Metrics Collection
  prometheus:
    image: prom/prometheus:latest
    container_name: prometheus-playwright
    ports:
      - "${PROMETHEUS_PORT:-9090}:9090"
    volumes:
      - ./monitoring/prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - prometheus_data:/prometheus
      - prometheus_logs:/var/log/prometheus
    command:
      - '--config.file=/etc/prometheus/prometheus.yml'
      - '--storage.tsdb.path=/prometheus'
      - '--web.console.libraries=/etc/prometheus/console_libraries'
      - '--web.console.templates=/etc/prometheus/consoles'
      - '--storage.tsdb.retention.time=15d'
      - '--web.enable-lifecycle'
    networks:
      - chronos-network
    restart: unless-stopped
    profiles:
      - monitoring

  # Grafana Dashboard
  grafana:
    image: grafana/grafana:latest
    container_name: grafana-playwright
    ports:
      - "${GRAFANA_PORT:-3001}:3000"
    environment:
      - GF_SECURITY_ADMIN_PASSWORD=${GRAFANA_ADMIN_PASSWORD}
      - GF_USERS_ALLOW_SIGN_UP=false
      - GF_INSTALL_PLUGINS=grafana-piechart-panel
    volumes:
      - grafana_data:/var/lib/grafana
      - grafana_logs:/var/log/grafana
      - ./monitoring/grafana/dashboards:/etc/grafana/provisioning/dashboards:ro
      - ./monitoring/grafana/datasources:/etc/grafana/provisioning/datasources:ro
    networks:
      - chronos-network
    restart: unless-stopped
    profiles:
      - monitoring

  # Playwright Test Runner
  playwright-tests:
    build:
      context: ./backend
      dockerfile: Dockerfile.playwright
      args:
        - ENVIRONMENT=testing
        - PLAYWRIGHT_VERSION=${PLAYWRIGHT_VERSION:-1.40.0}
    container_name: playwright-test-runner
    environment:
      - ENVIRONMENT=testing
      - PLAYWRIGHT_BROWSER_TYPE=chromium
      - PLAYWRIGHT_HEADLESS=true
      - PLAYWRIGHT_TEST_MODE=true
      - DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
      - REDIS_URL=redis://redis:6379/8
    volumes:
      - playwright_test_data:/app/data/playwright
      - playwright_test_results:/app/test-results
      - ./backend/tests/playwright:/app/tests/playwright:ro
      - ./backend/config/playwright.toml:/app/config/playwright.toml:ro
    networks:
      - chronos-network
    profiles:
      - testing
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy

  # Browser Image (for pre-loading browser binaries)
  browser-images:
    build:
      context: ./backend
      dockerfile: Dockerfile.playwright-images
      args:
        - PLAYWRIGHT_VERSION=${PLAYWRIGHT_VERSION:-1.40.0}
    image: playwright-mcp:browser-images
    container_name: playwright-browser-images
    volumes:
      - playwright_browsers:/app/playwright/browsers
    networks:
      - chronos-network
    profiles:
      - setup

# Named Volumes for Persistent Data
volumes:
  # Data Volumes
  playwright_data:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: ./data/playwright
  playwright_logs:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: ./logs/playwright
  playwright_backups:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: ./backups/playwright
  playwright_profiles:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: ./data/playwright/profiles
  playwright_artifacts:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: ./data/playwright/artifacts
  playwright_temp:
    driver: local
  playwright_downloads:
    driver: local
  playwright_node_modules:
    driver: local

  # Development Volumes
  playwright_dev_data:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: ./data/playwright-dev
  playwright_dev_logs:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: ./logs/playwright-dev
  playwright_dev_profiles:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: ./data/playwright-dev/profiles

  # Test Volumes
  playwright_test_data:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: ./data/playwright-test
  playwright_test_results:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: ./test-results/playwright

  # Browser Cache
  playwright_browsers:
    driver: local

  # Database Volumes
  postgres_data:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: ./data/postgres
  postgres_logs:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: ./logs/postgres

  # Redis Volumes
  redis_data:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: ./data/redis
  redis_logs:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: ./logs/redis

  # MinIO Volumes
  minio_data:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: ./data/minio
  minio_logs:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: ./logs/minio

  # Monitoring Volumes
  prometheus_data:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: ./data/prometheus
  prometheus_logs:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: ./logs/prometheus

  grafana_data:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: ./data/grafana
  grafana_logs:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: ./logs/grafana

  # Nginx Volumes
  nginx_logs:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: ./logs/nginx

# Network Configuration
networks:
  chronos-network:
    driver: bridge
    ipam:
      config:
        - subnet: 172.20.0.0/16
    driver_opts:
      com.docker.network.bridge.name: chronos-playwright