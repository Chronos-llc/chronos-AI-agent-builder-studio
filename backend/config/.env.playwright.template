# Chronos AI - Playwright MCP Server Environment Configuration
# Copy this file to .env and update the values according to your environment

# =============================================================================
# PLAYWRIGHT MCP SERVER CONFIGURATION
# =============================================================================

# Playwright Server Settings
PLAYWRIGHT_SERVER_HOST=0.0.0.0
PLAYWRIGHT_SERVER_PORT=8004
PLAYWRIGHT_SERVER_WORKERS=4
PLAYWRIGHT_SERVER_TIMEOUT=300
PLAYWRIGHT_SERVER_MAX_REQUESTS=1000
PLAYWRIGHT_SERVER_MAX_REQUESTS_JITTER=100

# Browser Configuration
PLAYWRIGHT_BROWSER_TYPE=chromium  # chromium, firefox, webkit
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000
PLAYWRIGHT_VIEWPORT_WIDTH=1280
PLAYWRIGHT_VIEWPORT_HEIGHT=720

# Browser Pool Settings
PLAYWRIGHT_POOL_SIZE=5
PLAYWRIGHT_POOL_TIMEOUT=60000
PLAYWRIGHT_POOL_MAX_WAIT=5000

# Resource Limits
PLAYWRIGHT_MAX_CONCURRENT_SESSIONS=10
PLAYWRIGHT_MAX_SESSION_DURATION=3600  # seconds
PLAYWRIGHT_MAX_MEMORY_PER_SESSION=256  # MB
PLAYWRIGHT_MAX_CPU_PER_SESSION=0.5  # 0-1 scale

# Security Settings
PLAYWRIGHT_ENABLE_VIDEO_RECORDING=false
PLAYWRIGHT_ENABLE_SCREENSHOT_CAPTURE=true
PLAYWRIGHT_ENABLE_DOWNLOADS=false
PLAYWRIGHT_DOWNLOAD_DIR=/tmp/playwright_downloads
PLAYWRIGHT_TEMP_DIR=/tmp/playwright_temp

# Network Configuration
PLAYWRIGHT_IGNORE_HTTPS_ERRORS=false
PLAYWRIGHT_USER_AGENT=  # Leave empty for default
PLAYWRIGHT_VIEWPORT_MOBILE=false

# Automation Settings
PLAYWRIGHT_SLOW_MO=0  # milliseconds
PLAYWRIGHT_AUTO_WAIT_TIMEOUT=30000
PLAYWRIGHT_ACTION_TIMEOUT=10000

# Proxy Configuration (Optional)
# PLAYWRIGHT_PROXY_URL=http://proxy.company.com:8080
# PLAYWRIGHT_PROXY_USERNAME=
# PLAYWRIGHT_PROXY_PASSWORD=

# Cookie and Storage Settings
PLAYWRIGHT_CLEAR_COOKIES_ON_START=true
PLAYWRIGHT_CLEAR_LOCAL_STORAGE_ON_START=true
PLAYWRIGHT_SAVE_COOKIES_ON_END=false
PLAYWRIGHT_COOKIES_FILE=  # Leave empty for no cookies file

# Logging Configuration
PLAYWRIGHT_LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
PLAYWRIGHT_ENABLE_CONSOLE_LOGS=true
PLAYWRIGHT_ENABLE_NETWORK_LOGS=false
PLAYWRIGHT_LOG_RETENTION_DAYS=7

# Artifact Storage
PLAYWRIGHT_ARTIFACT_STORAGE_BACKEND=local  # local, s3, minio
PLAYWRIGHT_ARTIFACT_STORAGE_PATH=/app/data/playwright/artifacts
PLAYWRIGHT_MAX_ARTIFACT_SIZE=100  # MB
PLAYWRIGHT_ARTIFACT_RETENTION_DAYS=30

# Performance Monitoring
PLAYWRIGHT_ENABLE_PERFORMANCE_MONITORING=true
PLAYWRIGHT_PERFORMANCE_METRICS_INTERVAL=5000  # milliseconds
PLAYWRIGHT_MEMORY_THRESHOLD_MB=512
PLAYWRIGHT_CPU_THRESHOLD_PERCENT=80

# Cleanup Settings
PLAYWRIGHT_CLEANUP_INTERVAL=3600  # seconds
PLAYWRIGHT_MAX_SESSION_IDLE_TIME=1800  # seconds
PLAYWRIGHT_ENABLE_AUTO_CLEANUP=true

# Artifact Types Configuration
PLAYWRIGHT_VIDEO_ENABLED=false
PLAYWRIGHT_VIDEO_FORMAT=mp4
PLAYWRIGHT_VIDEO_QUALITY=high

PLAYWRIGHT_SCREENSHOT_ENABLED=true
PLAYWRIGHT_SCREENSHOT_FORMAT=png
PLAYWRIGHT_SCREENSHOT_FULL_PAGE=false

PLAYWRIGHT_PDF_ENABLED=false
PLAYWRIGHT_PDF_FORMAT=pdf
PLAYWRIGHT_PDF_LANDSCAPE=false

PLAYWRIGHT_TRACE_ENABLED=true
PLAYWRIGHT_TRACE_FORMAT=zip
PLAYWRIGHT_TRACE_SCREENSHOTS=true
PLAYWRIGHT_TRACE_SNAPSHOTS=true

# Browser Options
PLAYWRIGHT_CHROMIUM_OPTIONS="--no-sandbox,--disable-dev-shm-usage,--disable-web-security"
PLAYWRIGHT_FIREFOX_OPTIONS="--no-sandbox,--disable-dev-shm-usage"
PLAYWRIGHT_WEBKIT_OPTIONS="--no-sandbox,--disable-dev-shm-usage"

# User Data Directories
PLAYWRIGHT_CHROME_PROFILE_DIR=/app/data/playwright/profiles/chrome
PLAYWRIGHT_FIREFOX_PROFILE_DIR=/app/data/playwright/profiles/firefox
PLAYWRIGHT_WEBKIT_PROFILE_DIR=/app/data/playwright/profiles/webkit

# Notification Settings
PLAYWRIGHT_ENABLE_NOTIFICATIONS=false
PLAYWRIGHT_NOTIFICATION_TIMEOUT=5000

# Geolocation Settings
PLAYWRIGHT_GEOLOCATION_ENABLED=false
PLAYWRIGHT_GEOLOCATION_LATITUDE=37.7749
PLAYWRIGHT_GEOLOCATION_LONGITUDE=-122.4194
PLAYWRIGHT_GEOLOCATION_ACCURACY=1000

# Device Emulation
PLAYWRIGHT_EMULATE_DEVICE=  # iPhone, iPad, Android, etc.
PLAYWRIGHT_EMULATE_USER_AGENT=
PLAYWRIGHT_EMULATE_VIEWPORT=

# Timezone Settings
PLAYWRIGHT_TIMEZONE=  # America/New_York, UTC, etc.
PLAYWRIGHT_TIMEZONE_OFFSET=  # -300 for EST, 0 for UTC, etc.

# =============================================================================
# MCP SERVER AUTHENTICATION & SECURITY
# =============================================================================

# API Keys and Authentication
PLAYWRIGHT_API_KEY=your-playwright-api-key-here
PLAYWRIGHT_ADMIN_API_KEY=your-admin-api-key-here
PLAYWRIGHT_JWT_SECRET_KEY=your-jwt-secret-key-here
PLAYWRIGHT_JWT_ALGORITHM=HS256
PLAYWRIGHT_JWT_EXPIRE_MINUTES=60

# Rate Limiting
PLAYWRIGHT_RATE_LIMIT_ENABLED=true
PLAYWRIGHT_RATE_LIMIT_REQUESTS=100
PLAYWRIGHT_RATE_LIMIT_WINDOW=60  # seconds

# CORS Settings
PLAYWRIGHT_CORS_ENABLED=true
PLAYWRIGHT_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]
PLAYWRIGHT_CORS_METHODS=["GET", "POST", "PUT", "DELETE", "OPTIONS"]
PLAYWRIGHT_CORS_HEADERS=["*"]

# SSL/TLS Configuration
PLAYWRIGHT_SSL_ENABLED=false
PLAYWRIGHT_SSL_CERT_FILE=
PLAYWRIGHT_SSL_KEY_FILE=

# Security Headers
PLAYWRIGHT_SECURITY_HEADERS_ENABLED=true
PLAYWRIGHT_SECURITY_HEADERS_CONTENT_SECURITY_POLICY="default-src 'self'"
PLAYWRIGHT_SECURITY_HEADERS_X_FRAME_OPTIONS="DENY"
PLAYWRIGHT_SECURITY_HEADERS_X_CONTENT_TYPE_OPTIONS="nosniff"

# =============================================================================
# DATABASE CONFIGURATION (for Playwright session data)
# =============================================================================

# Database Connection
PLAYWRIGHT_DATABASE_URL=postgresql://user:password@localhost:5432/chronos_ai_playwright

# Connection Pool Settings
PLAYWRIGHT_DB_POOL_SIZE=5
PLAYWRIGHT_DB_MAX_OVERFLOW=10
PLAYWRIGHT_DB_POOL_TIMEOUT=30
PLAYWRIGHT_DB_POOL_RECYCLE=3600

# Database Migration
PLAYWRIGHT_DB_MIGRATE_ON_STARTUP=true

# =============================================================================
# REDIS CONFIGURATION (for caching and session management)
# =============================================================================

# Redis Connection
PLAYWRIGHT_REDIS_URL=redis://localhost:6379/8
PLAYWRIGHT_REDIS_PASSWORD=
PLAYWRIGHT_REDIS_TIMEOUT=30

# Cache Settings
PLAYWRIGHT_CACHE_TTL=3600  # seconds
PLAYWRIGHT_SESSION_CACHE_TTL=1800  # seconds

# =============================================================================
# MONITORING & HEALTH CHECKS
# =============================================================================

# Health Check Settings
PLAYWRIGHT_HEALTH_CHECK_ENABLED=true
PLAYWRIGHT_HEALTH_CHECK_ENDPOINT=/health
PLAYWRIGHT_HEALTH_CHECK_TIMEOUT=10

# Metrics Collection
PLAYWRIGHT_METRICS_ENABLED=true
PLAYWRIGHT_METRICS_ENDPOINT=/metrics
PLAYWRIGHT_METRICS_PORT=9090

# Logging
PLAYWRIGHT_LOG_FORMAT=json
PLAYWRIGHT_LOG_FILE=/app/logs/playwright/server.log
PLAYWRIGHT_LOG_MAX_SIZE=100  # MB
PLAYWRIGHT_LOG_BACKUP_COUNT=10

# =============================================================================
# EXTERNAL SERVICE INTEGRATIONS
# =============================================================================

# S3 Storage (if using S3 for artifacts)
PLAYWRIGHT_S3_BUCKET=
PLAYWRIGHT_S3_REGION=us-east-1
PLAYWRIGHT_S3_ACCESS_KEY=
PLAYWRIGHT_S3_SECRET_KEY=
PLAYWRIGHT_S3_ENDPOINT=  # For MinIO or other S3-compatible services

# MinIO Storage (if using MinIO for artifacts)
PLAYWRIGHT_MINIO_ENDPOINT=localhost:9000
PLAYWRIGHT_MINIO_ACCESS_KEY=
PLAYWRIGHT_MINIO_SECRET_KEY=
PLAYWRIGHT_MINIO_SECURE=false

# Notification Services
PLAYWRIGHT_SLACK_WEBHOOK_URL=
PLAYWRIGHT_EMAIL_SMTP_HOST=
PLAYWRIGHT_EMAIL_SMTP_PORT=587
PLAYWRIGHT_EMAIL_SMTP_USERNAME=
PLAYWRIGHT_EMAIL_SMTP_PASSWORD=
PLAYWRIGHT_EMAIL_FROM=playwright@chronos-ai.com

# =============================================================================
# DEVELOPMENT & DEBUG SETTINGS
# =============================================================================

# Development Mode
PLAYWRIGHT_DEBUG_MODE=false
PLAYWRIGHT_DEV_SERVER=true
PLAYWRIGHT_HOT_RELOAD=false

# Testing
PLAYWRIGHT_TEST_MODE=false
PLAYWRIGHT_TEST_TIMEOUT=30000
PLAYWRIGHT_TEST_BROWSERS=["chromium", "firefox", "webkit"]

# Feature Flags
PLAYWRIGHT_FEATURE_ADVANCED_SELECTORS=true
PLAYWRIGHT_FEATURE_SMART_WAITING=true
PLAYWRIGHT_FEATURE_AUTO_RETRY=true
PLAYWRIGHT_FEATURE_PERFORMANCE_MONITORING=true

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================

# Connection Pooling
PLAYWRIGHT_HTTP_POOL_CONNECTIONS=10
PLAYWRIGHT_HTTP_POOL_MAXSIZE=20
PLAYWRIGHT_HTTP_POOL_STALE=10

# Memory Management
PLAYWRIGHT_MEMORY_CLEANUP_INTERVAL=300  # seconds
PLAYWRIGHT_MEMORY_THRESHOLD_MB=1024
PLAYWRIGHT_SWAP_THRESHOLD_MB=2048

# CPU Optimization
PLAYWRIGHT_CPU_AFFINITY=  # CPU core numbers for process affinity
PLAYWRIGHT_WORKER_PROCESSES=auto

# =============================================================================
# BACKUP & RECOVERY
# =============================================================================

# Backup Settings
PLAYWRIGHT_BACKUP_ENABLED=true
PLAYWRIGHT_BACKUP_INTERVAL=86400  # 24 hours in seconds
PLAYWRIGHT_BACKUP_RETENTION_DAYS=30
PLAYWRIGHT_BACKUP_LOCATION=/app/backups/playwright

# Recovery Settings
PLAYWRIGHT_RECOVERY_ENABLED=true
PLAYWRIGHT_AUTO_RECOVERY=true
PLAYWRIGHT_RECOVERY_MAX_ATTEMPTS=3
PLAYWRIGHT_RECOVERY_BACKOFF_SECONDS=60