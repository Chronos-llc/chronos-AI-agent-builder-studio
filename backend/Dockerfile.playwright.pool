# Playwright Pool Manager Dockerfile
# Lightweight service for managing browser pools

FROM ubuntu:22.04 as base

# Install system dependencies
RUN apt-get update && apt-get install -y \
    # Browser dependencies
    libglib2.0-0 \
    libnss3 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libxkbcommon0 \
    libxcomposite1 \
    libxdamage1 \
    libxrandr2 \
    libgbm1 \
    libasound2 \
    libpango-1.0-0 \
    libcairo2 \
    libgtk-3-0 \
    libu2f-udev \
    libvulkan1 \
    libxshmfence1 \
    # Python and development tools
    python3 \
    python3-pip \
    python3-venv \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Set environment variables
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# Set working directory
WORKDIR /app

# Install Python dependencies
RUN pip install --upgrade pip && \
    pip install playwright fastapi uvicorn aioredis redis asyncio-mqtt

# Install Playwright browsers
RUN pip install playwright && \
    playwright install chromium && \
    playwright install-deps chromium

# Copy pool manager code
COPY backend/scripts/playwright_pool_manager.py ./pool_manager.py
COPY backend/app/core/playwright.py ./playwright_core.py

# Create necessary directories
RUN mkdir -p /app/pools /app/logs && \
    chmod -R 755 /app

# Create non-root user
RUN useradd --create-home --shell /bin/bash chronos

# Switch to non-root user
USER chronos

# Expose port for pool manager
EXPOSE 8002

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=20s --retries=3 \
    CMD curl -f http://localhost:8002/health || exit 1

# Pool manager command
CMD ["python", "-m", "pool_manager"]