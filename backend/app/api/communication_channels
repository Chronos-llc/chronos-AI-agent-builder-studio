@router.put("/{channel_id}", response_model=CommunicationChannelSchema)
async def update_communication_channel(
    channel_id: int,
    channel_update: CommunicationChannelUpdate,
    db: Session = Depends(get_db),
    current_user: User = Depends(get_current_user)
):
    """Update a communication channel."""
    channel = db.query(CommunicationChannel).filter(
        CommunicationChannel.id == channel_id
    ).join(Agent).filter(
        Agent.user_id == current_user.id
    ).first()
    
    if not channel:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail="Communication channel not found"
        )
    
    # Check for duplicate names if name is being updated
    if channel_update.name and channel_update.name != channel.name:
        existing_channel = db.query(CommunicationChannel).filter(
            CommunicationChannel.agent_id == channel.agent_id,
            CommunicationChannel.name == channel_update.name,
            CommunicationChannel.id != channel_id
        ).first()
        if existing_channel:
            raise HTTPException(
                status_code=status.HTTP_400_BAD_REQUEST,
                detail="A channel with this name already exists for this agent"
            )
    
    update_data = channel_update.model_dump(exclude_unset=True)
    for field, value in update_data.items():
        setattr(channel, field, value)
    
    db.commit()
    db.refresh(channel)
    return channel


