@router.post("/webchat", response_model=Dict[str, Any])
async def create_webchat_channel(
    channel_data: WebChatChannelCreate,
    background_tasks: BackgroundTasks,
    db: Session = Depends(get_db),
    current_user: User = Depends(get_current_user)
):
    """Create a new web chat channel."""
    # Verify the agent exists and belongs to the current user
    agent = db.query(Agent).filter(
        Agent.id == channel_data.agent_id,
        Agent.user_id == current_user.id
    ).first()
    if not agent:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail="Agent not found"
        )
    
    # Check for duplicate channel names
    existing_channel = db.query(CommunicationChannel).filter(
        CommunicationChannel.agent_id == channel_data.agent_id,
        CommunicationChannel.name == channel_data.name
    ).first()
    if existing_channel:
        raise HTTPException(
            status_code=status.HTTP_400_BAD_REQUEST,
            detail="A channel with this name already exists for this agent"
        )
    
    # Create the channel
    channel_config = channel_data.model_dump()
    db_channel = CommunicationChannel(
        agent_id=channel_data.agent_id,
        name=channel_data.name,
        type="webchat",
        description=channel_data.description,
        configuration=channel_config
    )
    db.add(db_channel)
    db.commit()
    db.refresh(db_channel)
    
    # Initialize the web chat channel in background
    background_tasks.add_task(
        WebChatChannelManager.initialize_channel,
        db_channel.id,
        channel_config
    )
    
    # Generate embed code
    embed_code = f'''
    <script>
        (function() {{
            var script = document.createElement('script');
            script.src = '{channel_config.get("embed_url", "https://your-domain.com/webchat.js")}';
            script.setAttribute('data-agent-id', '{channel_data.agent_id}');
            script.setAttribute('data-channel-id', '{db_channel.id}');
            document.head.appendChild(script);
        }})();
    </script>
    '''
    
    return {
        "channel": db_channel,
        "embed_code": embed_code,
        "configuration": WebChatConfiguration(
            theme=channel_data.theme,
            position=channel_data.position,
            show_avatar=channel_data.show_avatar,
            welcome_message=channel_data.welcome_message,
            embed_code=embed_code
        )
    }


