    TelegramChannelManager,
    SlackChannelManager,
    WebChatChannelManager,
    WhatsAppChannelManager
)

router = APIRouter(prefix="/api/communication-channels", tags=["communication-channels"])


@router.get("/", response_model=List[CommunicationChannelSchema])
async def get_communication_channels(
    agent_id: Optional[int] = None,
    db: Session = Depends(get_db),
    current_user: User = Depends(get_current_user)
):
    """Get all communication channels for the current user's agents."""
    query = db.query(CommunicationChannel)
    
    if agent_id:
        # Verify the agent belongs to the current user
        agent = db.query(Agent).filter(
            Agent.id == agent_id,
            Agent.user_id == current_user.id
        ).first()
        if not agent:
            raise HTTPException(
                status_code=status.HTTP_404_NOT_FOUND,
                detail="Agent not found"
            )
        query = query.filter(CommunicationChannel.agent_id == agent_id)
    else:
        # Only get channels for agents owned by the current user
        query = query.join(Agent).filter(Agent.user_id == current_user.id)
    
    channels = query.all()
    return channels


@router.post("/", response_model=CommunicationChannelSchema)
async def create_communication_channel(
    channel_data: CommunicationChannelCreate,
    db: Session = Depends(get_db),
    current_user: User = Depends(get_current_user)
):
    """Create a new communication channel."""
    # Verify the agent exists and belongs to the current user
    if channel_data.agent_id:
        agent = db.query(Agent).filter(
            Agent.id == channel_data.agent_id,
            Agent.user_id == current_user.id
        ).first()
        if not agent:
            raise HTTPException(
                status_code=status.HTTP_404_NOT_FOUND,
                detail="Agent not found"
            )
    
    # Check for duplicate channel names for the same agent
    if channel_data.agent_id:
        existing_channel = db.query(CommunicationChannel).filter(
            CommunicationChannel.agent_id == channel_data.agent_id,
            CommunicationChannel.name == channel_data.name
        ).first()
        if existing_channel:
            raise HTTPException(
                status_code=status.HTTP_400_BAD_REQUEST,
                detail="A channel with this name already exists for this agent"
            )
    
    db_channel = CommunicationChannel(**channel_data.model_dump())
    db.add(db_channel)
    db.commit()
    db.refresh(db_channel)
    return db_channel


