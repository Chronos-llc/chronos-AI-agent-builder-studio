@router.get("/{channel_id}/status", response_model=Dict[str, Any])
async def get_channel_status(
    channel_id: int,
    db: Session = Depends(get_db),
    current_user: User = Depends(get_current_user)
):
    """Get the status of a communication channel."""
    channel = db.query(CommunicationChannel).filter(
        CommunicationChannel.id == channel_id
    ).join(Agent).filter(
        Agent.user_id == current_user.id
    ).first()
    
    if not channel:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail="Communication channel not found"
        )
    
    # Get status based on channel type
    if channel.type == "telegram":
        status_info = await TelegramChannelManager.get_channel_status(channel.id)
    elif channel.type == "slack":
        status_info = await SlackChannelManager.get_channel_status(channel.id)
    elif channel.type == "webchat":
        status_info = await WebChatChannelManager.get_channel_status(channel.id)
    elif channel.type == "whatsapp":
        status_info = await WhatsAppChannelManager.get_channel_status(channel.id)
    else:
        status_info = {"status": "unknown", "message": "Unknown channel type"}
    
    return {
        "channel_id": channel.id,
        "channel_type": channel.type,
        "is_active": channel.is_active,
        **status_info
    }


@router.post("/{channel_id}/activate")
async def activate_channel(
    channel_id: int,
    db: Session = Depends(get_db),
    current_user: User = Depends(get_current_user)
):
    """Activate a communication channel."""
    channel = db.query(CommunicationChannel).filter(
        CommunicationChannel.id == channel_id
    ).join(Agent).filter(
        Agent.user_id == current_user.id
    ).first()
    
    if not channel:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail="Communication channel not found"
        )
    
    channel.is_active = True
    db.commit()
    
    # Activate based on channel type
    if channel.type == "telegram":
        await TelegramChannelManager.activate_channel(channel.id)
    elif channel.type == "slack":
        await SlackChannelManager.activate_channel(channel.id)
    elif channel.type == "webchat":
        await WebChatChannelManager.activate_channel(channel.id)
    elif channel.type == "whatsapp":
        await WhatsAppChannelManager.activate_channel(channel.id)
    
    return {"message": f"{channel.type} channel activated successfully"}


