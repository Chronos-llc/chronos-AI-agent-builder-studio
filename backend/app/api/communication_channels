    CommunicationChannel as CommunicationChannelSchema,
    CommunicationChannelCreate,
    CommunicationChannelUpdate,
    WebChatChannelCreate,
    WebChatConfiguration,
    TelegramChannelCreate,
    SlackChannelCreate,
    WhatsAppChannelCreate
