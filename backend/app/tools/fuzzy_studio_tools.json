{
    "tools": [
        {
            "name": "create_agent",
            "description": "Create a new agent with specified configuration. Use this when the user wants to build or create a new agent.",
            "category": "agent_management",
            "parameters": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string",
                        "description": "Name of the agent (1-100 characters)",
                        "required": true
                    },
                    "description": {
                        "type": "string",
                        "description": "Description of what the agent does",
                        "required": false
                    },
                    "system_prompt": {
                        "type": "string",
                        "description": "System instructions that define the agent's behavior and personality",
                        "required": false
                    },
                    "model_config": {
                        "type": "object",
                        "description": "LLM model configuration (model name, temperature, max_tokens, etc.)",
                        "required": false
                    },
                    "tags": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "description": "Tags for categorizing the agent",
                        "required": false
                    }
                }
            },
            "returns": {
                "type": "object",
                "properties": {
                    "success": {
                        "type": "boolean"
                    },
                    "message": {
                        "type": "string"
                    },
                    "data": {
                        "type": "object",
                        "properties": {
                            "agent_id": {
                                "type": "integer"
                            },
                            "agent_name": {
                                "type": "string"
                            },
                            "status": {
                                "type": "string"
                            }
                        }
                    }
                }
            },
            "examples": [
                {
                    "user_request": "Create a customer support agent",
                    "parameters": {
                        "name": "Customer Support Bot",
                        "description": "Helps customers with product questions and issues",
                        "system_prompt": "You are a helpful customer support agent. Be polite, professional, and solve customer problems efficiently."
                    }
                }
            ]
        },
        {
            "name": "update_agent_config",
            "description": "Update an existing agent's configuration including name, description, system prompt, model config, or tags.",
            "category": "agent_management",
            "parameters": {
                "type": "object",
                "properties": {
                    "agent_id": {
                        "type": "integer",
                        "description": "ID of the agent to update",
                        "required": true
                    },
                    "name": {
                        "type": "string",
                        "description": "New name for the agent",
                        "required": false
                    },
                    "description": {
                        "type": "string",
                        "description": "New description",
                        "required": false
                    },
                    "system_prompt": {
                        "type": "string",
                        "description": "New system prompt/instructions",
                        "required": false
                    },
                    "model_config": {
                        "type": "object",
                        "description": "New model configuration",
                        "required": false
                    },
                    "tags": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "description": "New tags",
                        "required": false
                    }
                }
            },
            "returns": {
                "type": "object",
                "properties": {
                    "success": {
                        "type": "boolean"
                    },
                    "message": {
                        "type": "string"
                    },
                    "data": {
                        "type": "object",
                        "properties": {
                            "agent_id": {
                                "type": "integer"
                            },
                            "agent_name": {
                                "type": "string"
                            }
                        }
                    }
                }
            },
            "examples": [
                {
                    "user_request": "Update the agent's name to 'Sales Assistant'",
                    "parameters": {
                        "agent_id": 123,
                        "name": "Sales Assistant"
                    }
                }
            ]
        },
        {
            "name": "delete_agent",
            "description": "Delete an agent permanently. This action cannot be undone.",
            "category": "agent_management",
            "parameters": {
                "type": "object",
                "properties": {
                    "agent_id": {
                        "type": "integer",
                        "description": "ID of the agent to delete",
                        "required": true
                    },
                    "confirm": {
                        "type": "boolean",
                        "description": "Confirmation flag (must be true)",
                        "required": true
                    }
                }
            },
            "returns": {
                "type": "object",
                "properties": {
                    "success": {
                        "type": "boolean"
                    },
                    "message": {
                        "type": "string"
                    },
                    "data": {
                        "type": "object",
                        "properties": {
                            "agent_id": {
                                "type": "integer"
                            }
                        }
                    }
                }
            },
            "examples": [
                {
                    "user_request": "Delete the test agent",
                    "parameters": {
                        "agent_id": 123,
                        "confirm": true
                    }
                }
            ]
        },
        {
            "name": "list_user_agents",
            "description": "Get a list of all agents owned by the user. Can filter by status and paginate results.",
            "category": "query",
            "parameters": {
                "type": "object",
                "properties": {
                    "status": {
                        "type": "string",
                        "enum": [
                            "draft",
                            "active",
                            "inactive",
                            "archived"
                        ],
                        "description": "Filter agents by status",
                        "required": false
                    },
                    "limit": {
                        "type": "integer",
                        "description": "Maximum number of agents to return (1-100)",
                        "default": 50,
                        "required": false
                    },
                    "offset": {
                        "type": "integer",
                        "description": "Offset for pagination",
                        "default": 0,
                        "required": false
                    }
                }
            },
            "returns": {
                "type": "object",
                "properties": {
                    "agents": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "id": {
                                    "type": "integer"
                                },
                                "name": {
                                    "type": "string"
                                },
                                "description": {
                                    "type": "string"
                                },
                                "status": {
                                    "type": "string"
                                },
                                "tags": {
                                    "type": "array"
                                },
                                "created_at": {
                                    "type": "string"
                                },
                                "updated_at": {
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "total": {
                        "type": "integer"
                    },
                    "limit": {
                        "type": "integer"
                    },
                    "offset": {
                        "type": "integer"
                    }
                }
            },
            "examples": [
                {
                    "user_request": "Show me all my active agents",
                    "parameters": {
                        "status": "active",
                        "limit": 50,
                        "offset": 0
                    }
                }
            ]
        },
        {
            "name": "get_agent_details",
