                                "type": "string"
                            }
                        }
                    }
                }
            },
            "examples": [
                {
                    "user_request": "Add the product documentation to the agent's knowledge base",
                    "parameters": {
                        "agent_id": 123,
                        "file_name": "product_docs.pdf",
                        "file_type": "pdf",
                        "file_url": "https://example.com/docs/product.pdf"
                    }
                }
            ]
        },
        {
            "name": "configure_communication_channel",
            "description": "Configure a communication channel (Slack, Discord, Telegram, etc.) for the agent.",
            "category": "studio_configuration",
            "parameters": {
                "type": "object",
                "properties": {
                    "agent_id": {
                        "type": "integer",
                        "description": "ID of the agent",
                        "required": true
                    },
                    "channel_type": {
                        "type": "string",
                        "description": "Type of channel (slack, discord, telegram, whatsapp, etc.)",
                        "required": true
                    },
                    "channel_config": {
                        "type": "object",
                        "description": "Channel-specific configuration (API keys, webhooks, etc.)",
                        "required": true
                    },
                    "is_active": {
                        "type": "boolean",
                        "description": "Whether the channel is active",
                        "default": true,
                        "required": false
                    }
                }
            },
            "returns": {
                "type": "object",
                "properties": {
                    "success": {
                        "type": "boolean"
                    },
                    "message": {
                        "type": "string"
                    },
                    "data": {
                        "type": "object",
                        "properties": {
                            "channel_id": {
                                "type": "integer"
                            },
                            "channel_type": {
                                "type": "string"
                            }
                        }
                    }
                }
            },
            "examples": [
                {
                    "user_request": "Connect the agent to our Slack workspace",
                    "parameters": {
                        "agent_id": 123,
                        "channel_type": "slack",
                        "channel_config": {
                            "bot_token": "xoxb-...",
                            "signing_secret": "..."
                        },
                        "is_active": true
                    }
                }
            ]
        },
        {
            "name": "publish_agent",
            "description": "Publish an agent to make it active on specified communication channels.",
            "category": "publishing",
            "parameters": {
                "type": "object",
                "properties": {
                    "agent_id": {
                        "type": "integer",
                        "description": "ID of the agent to publish",
                        "required": true
                    },
                    "channels": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "description": "List of channels to publish to",
                        "required": true
                    },
                    "publish_config": {
                        "type": "object",
                        "description": "Publishing configuration",
                        "required": false
                    }
                }
            },
            "returns": {
                "type": "object",
                "properties": {
                    "success": {
                        "type": "boolean"
                    },
                    "message": {
                        "type": "string"
                    },
                    "data": {
                        "type": "object",
                        "properties": {
                            "agent_id": {
                                "type": "integer"
                            },
                            "channels": {
                                "type": "array"
                            }
                        }
                    }
                }
            },
            "examples": [
                {
                    "user_request": "Publish the agent to Slack and Discord",
                    "parameters": {
                        "agent_id": 123,
                        "channels": [
                            "slack",
                            "discord"
                        ]
                    }
                }
            ]
        },
        {
            "name": "unpublish_agent",
            "description": "Unpublish an agent to make it inactive and remove it from channels.",
            "category": "publishing",
            "parameters": {
                "type": "object",
                "properties": {
                    "agent_id": {
                        "type": "integer",
                        "description": "ID of the agent to unpublish",
                        "required": true
                    },
                    "channels": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "description": "Specific channels to unpublish from (null = all channels)",
                        "required": false
                    }
                }
            },
            "returns": {
                "type": "object",
                "properties": {
                    "success": {
                        "type": "boolean"
                    },
                    "message": {
                        "type": "string"
                    },
                    "data": {
                        "type": "object",
                        "properties": {
                            "agent_id": {
                                "type": "integer"
                            }
                        }
                    }
                }
            },
            "examples": [
                {
                    "user_request": "Unpublish the agent from all channels",
                    "parameters": {
                        "agent_id": 123
                    }
                }
            ]
        },
