                        "type": "string"
                    },
                    "status": {
                        "type": "string"
                    },
                    "system_prompt": {
                        "type": "string"
                    },
                    "model_config": {
                        "type": "object"
                    },
                    "tags": {
                        "type": "array"
                    },
                    "tools": {
                        "type": "array"
                    },
                    "knowledge_files": {
                        "type": "array"
                    },
                    "communication_channels": {
                        "type": "array"
                    },
                    "created_at": {
                        "type": "string"
                    },
                    "updated_at": {
                        "type": "string"
                    }
                }
            },
            "examples": [
                {
                    "user_request": "Show me details about agent 123",
                    "parameters": {
                        "agent_id": 123
                    }
                }
            ]
        },
        {
            "name": "add_tool_to_agent",
            "description": "Add a tool/capability to an agent. Tools enable agents to perform specific actions like web scraping, API calls, etc.",
            "category": "studio_configuration",
            "parameters": {
                "type": "object",
                "properties": {
                    "agent_id": {
                        "type": "integer",
                        "description": "ID of the agent",
                        "required": true
                    },
                    "tool_name": {
                        "type": "string",
                        "description": "Name of the tool",
                        "required": true
                    },
                    "tool_type": {
                        "type": "string",
                        "description": "Type of tool (function, api_call, web_scraping, database_query, etc.)",
                        "required": true
                    },
                    "tool_config": {
                        "type": "object",
                        "description": "Tool-specific configuration",
                        "required": false
                    },
                    "parameters": {
                        "type": "object",
                        "description": "Tool parameters",
                        "required": false
                    }
                }
            },
            "returns": {
                "type": "object",
                "properties": {
                    "success": {
                        "type": "boolean"
                    },
                    "message": {
                        "type": "string"
                    },
                    "data": {
                        "type": "object",
                        "properties": {
                            "tool_id": {
                                "type": "integer"
                            },
                            "tool_name": {
                                "type": "string"
                            }
                        }
                    }
                }
            },
            "examples": [
                {
                    "user_request": "Add web scraping capability to the agent",
                    "parameters": {
                        "agent_id": 123,
                        "tool_name": "Web Scraper",
                        "tool_type": "web_scraping",
                        "tool_config": {
                            "max_pages": 10,
                            "timeout": 30
                        }
                    }
                }
            ]
        },
