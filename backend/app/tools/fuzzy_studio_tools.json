        {
            "name": "add_knowledge_file",
            "description": "Add a knowledge base file to an agent so it can reference specific information.",
            "category": "studio_configuration",
            "parameters": {
                "type": "object",
                "properties": {
                    "agent_id": {
                        "type": "integer",
                        "description": "ID of the agent",
