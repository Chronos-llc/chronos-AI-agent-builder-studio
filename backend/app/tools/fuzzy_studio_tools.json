                    "file_type": {
                        "type": "string",
                        "description": "Type of file (pdf, txt, docx, etc.)",
                        "required": true
                    },
                    "file_content": {
                        "type": "string",
                        "description": "Content of the file (for text files)",
                        "required": false
                    },
                    "file_url": {
                        "type": "string",
                        "description": "URL to the file",
                        "required": false
