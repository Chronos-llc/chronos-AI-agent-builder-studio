# Chronos AI Agent Builder Studio - Backend Environment Configuration
# Copy this file from .env.example and update the values according to your environment

# ==============================================
# APPLICATION CORE CONFIGURATION
# ==============================================

# Application
APP_NAME=Chronos AI Agent Builder Studio
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development
DEBUG=True

# Database - Use SQLite for development by default
DATABASE_URL=sqlite+aiosqlite:///./chronos.db

# Redis
REDIS_URL=redis-11166.c277.us-east-1-3.ec2.cloud.redislabs.com:11166

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-this-in-production-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# Security
PASSWORD_MIN_LENGTH=8
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# ==============================================
# EMAIL CONFIGURATION
# ==============================================

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ==============================================
# EXTERNAL API KEYS
# ==============================================

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ==============================================
# MCP SERVER CONFIGURATION
# ==============================================

MCP_SERVER_URL=
MCP_SERVER_API_KEY=
MCP_SERVER_TIMEOUT=30

# ==============================================
# LOGGING CONFIGURATION
# ==============================================

LOG_LEVEL=INFO

# ==============================================
# PLAYWRIGHT MCP SERVER INTEGRATION
# ==============================================

PLAYWRIGHT_MCP_SERVER_NAME=chronos-playwright-mcp
PLAYWRIGHT_MCP_SERVER_VERSION=1.0.0
PLAYWRIGHT_MCP_SERVER_HOST=0.0.0.0
PLAYWRIGHT_MCP_SERVER_PORT=8001
PLAYWRIGHT_MCP_SERVER_WORKERS=4
PLAYWRIGHT_ENVIRONMENT=development
PLAYWRIGHT_DEBUG=False
PLAYWRIGHT_LOG_LEVEL=INFO

# Browser Configuration
PLAYWRIGHT_BROWSER_TYPE=chromium
PLAYWRIGHT_HEADLESS=True
PLAYWRIGHT_BROWSER_TIMEOUT=30000
PLAYWRIGHT_PAGE_TIMEOUT=30000

# Browser Pool Configuration
PLAYWRIGHT_BROWSER_POOL_SIZE=10
PLAYWRIGHT_BROWSER_MAX_POOL_SIZE=50
PLAYWRIGHT_BROWSER_IDLE_TIMEOUT=300
PLAYWRIGHT_BROWSER_REUSE_ENABLED=True
PLAYWRIGHT_BROWSER_AUTO_RESTART=True

# Task Execution Configuration
PLAYWRIGHT_TASK_QUEUE_ENABLED=True
PLAYWRIGHT_TASK_QUEUE_MAX_SIZE=1000
PLAYWRIGHT_TASK_CONCURRENCY=5
PLAYWRIGHT_TASK_TIMEOUT=300
PLAYWRIGHT_TASK_RETRY_ATTEMPTS=3
PLAYWRIGHT_TASK_RETRY_DELAY=5

# Automation Settings
PLAYWRIGHT_AUTO_SCROLL=True
PLAYWRIGHT_AUTO_WAIT=True
PLAYWRIGHT_WAIT_AFTER_ACTION=1000
PLAYWRIGHT_CLICK_DELAY=100
PLAYWRIGHT_TYPE_DELAY=50

# Screenshot and Recording
PLAYWRIGHT_SCREENSHOT_ENABLED=True
PLAYWRIGHT_SCREENSHOT_DIR=./screenshots
PLAYWRIGHT_SCREENSHOT_FORMAT=png
PLAYWRIGHT_SCREENSHOT_QUALITY=90
PLAYWRIGHT_RECORD_VIDEO_ENABLED=False
PLAYWRIGHT_RECORD_VIDEO_DIR=./recordings
PLAYWRIGHT_RECORD_VIDEO_FPS=30

# Storage Configuration
PLAYWRIGHT_ARTIFACT_STORAGE_TYPE=local
PLAYWRIGHT_ARTIFACT_STORAGE_PATH=./artifacts
PLAYWRIGHT_ARTIFACT_RETENTION_DAYS=30
PLAYWRIGHT_ARTIFACT_COMPRESSION=True
PLAYWRIGHT_ARTIFACT_ENCRYPTION=False

# Security Configuration
PLAYWRIGHT_AUTH_ENABLED=True
PLAYWRIGHT_AUTH_METHOD=jwt
PLAYWRIGHT_JWT_SECRET_KEY=your-playwright-jwt-secret-key-change-this
PLAYWRIGHT_JWT_ALGORITHM=HS256
PLAYWRIGHT_JWT_EXPIRATION_TIME=3600
PLAYWRIGHT_API_KEY_HEADER=X-API-Key

# CORS Configuration
PLAYWRIGHT_CORS_ORIGINS=["http://localhost:3000", "https://your-domain.com"]
PLAYWRIGHT_RATE_LIMIT_PER_MINUTE=60
PLAYWRIGHT_RATE_LIMIT_BURST=10
PLAYWRIGHT_TRUST_PROXY=False

# Proxy Configuration
PLAYWRIGHT_PROXY_ENABLED=False
PLAYWRIGHT_PROXY_SERVER=
PLAYWRIGHT_PROXY_USERNAME=
PLAYWRIGHT_PROXY_PASSWORD=
PLAYWRIGHT_PROXY_BYPASS=

# Logging Configuration
PLAYWRIGHT_LOG_DIR=./logs
PLAYWRIGHT_LOG_ROTATION=10MB
PLAYWRIGHT_LOG_RETENTION=30
PLAYWRIGHT_LOG_JSON_FORMAT=False
PLAYWRIGHT_LOG_SQL_QUERIES=False

# Metrics and Monitoring
PLAYWRIGHT_METRICS_ENABLED=True
PLAYWRIGHT_METRICS_PORT=9090
PLAYWRIGHT_PROMETHEUS_ENABLED=True
PLAYWRIGHT_SENTRY_DSN=
PLAYWRIGHT_HEALTH_CHECK_ENABLED=True

# Cache Configuration
PLAYWRIGHT_CACHE_ENABLED=True
PLAYWRIGHT_CACHE_TYPE=redis
PLAYWRIGHT_CACHE_TTL=3600
PLAYWRIGHT_CACHE_SIZE_LIMIT=1000
PLAYWRIGHT_REDIS_URL=redis://localhost:6379/0
PLAYWRIGHT_REDIS_PASSWORD=
PLAYWRIGHT_REDIS_SSL=False

# Integration Configuration
PLAYWRIGHT_CHRONOS_API_URL=http://localhost:8000
PLAYWRIGHT_CHRONOS_API_KEY=
PLAYWRIGHT_CHRONOS_WS_URL=ws://localhost:8000/ws
PLAYWRIGHT_MCP_CLIENT_ENABLED=True
PLAYWRIGHT_MCP_CLIENT_URL=http://localhost:8000/api/mcp
PLAYWRIGHT_MCP_CLIENT_TIMEOUT=30

# External Service Integrations
PLAYWRIGHT_2CAPTCHA_API_KEY=
PLAYWRIGHT_ANTICAPTCHA_CLIENT_KEY=
PLAYWRIGHT_CLOUDSCRAPER_ENABLED=True
PLAYWRIGHT_UNDETECTED_CHROMEDRIVER=True

# Development and Testing
PLAYWRIGHT_DEV_MODE=False
PLAYWRIGHT_HOT_RELOAD=False
PLAYWRIGHT_DEBUG_PORT=9222
PLAYWRIGHT_DEBUG_BROWSER=False
PLAYWRIGHT_TEST_TIMEOUT=60000
PLAYWRIGHT_TEST_RETRIES=0
PLAYWRIGHT_TEST_HEADLESS=True
PLAYWRIGHT_TEST_VIDEO=False
PLAYWRIGHT_TEST_SCREENSHOTS=False

# Advanced Features
PLAYWRIGHT_AI_ENABLED=False
PLAYWRIGHT_AI_PROVIDER=openai
PLAYWRIGHT_AI_MODEL=gpt-4
PLAYWRIGHT_AI_API_KEY=
PLAYWRIGHT_AI_TEMPERATURE=0.1
PLAYWRIGHT_ML_ENABLED=False
PLAYWRIGHT_ML_MODEL_PATH=./models/playwright-optimizer.pkl
PLAYWRIGHT_ML_TRAINING_DATA_PATH=./data/training
PLAYWRIGHT_ML_PERFORMANCE_THRESHOLD=0.8

# Social Media Automation
PLAYWRIGHT_SOCIAL_MEDIA_ENABLED=False
PLAYWRIGHT_FACEBOOK_APP_ID=
PLAYWRIGHT_FACEBOOK_APP_SECRET=
PLAYWRIGHT_TWITTER_API_KEY=
PLAYWRIGHT_TWITTER_API_SECRET=
PLAYWRIGHT_LINKEDIN_CLIENT_ID=
PLAYWRIGHT_LINKEDIN_CLIENT_SECRET=

# Customization Options
PLAYWRIGHT_USER_AGENT_ROTATION=False
PLAYWRIGHT_USER_AGENT_LIST_PATH=./config/user_agents.txt
PLAYWRIGHT_COOKIE_PERSISTENCE=False
PLAYWRIGHT_COOKIE_FILE_PATH=./cookies/cookies.json
PLAYWRIGHT_COOKIE_EXPIRY_DAYS=30
PLAYWRIGHT_EXTENSIONS_ENABLED=False
PLAYWRIGHT_EXTENSIONS_PATH=./extensions
PLAYWRIGHT_EXTENSIONS_AUTO_INSTALL=False
PLAYWRIGHT_CUSTOM_SCRIPTS_PATH=./scripts
PLAYWRIGHT_CUSTOM_HOOKS_ENABLED=True
