# Chronos AI Agent Builder Studio - Backend Environment Configuration
# Copy this file from .env.example and update the values according to your environment

# ==============================================
# APPLICATION CORE CONFIGURATION
# ==============================================

# Application
APP_NAME=Chronos AI Agent Builder Studio
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development
DEBUG=True

# Database - Use SQLite for development by default
DATABASE_URL=sqlite+aiosqlite:///./chronos.db

# Redis
REDIS_URL=redis://redis-11166.c277.us-east-1-3.ec2.cloud.redislabs.com:11166/0

# JWT Configuration
SECRET_KEY=EFCA0BjY8uB6k54N-J0At-4b2E2t6pZE-vDmsgKEK8Q
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# Security
PASSWORD_MIN_LENGTH=8
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# ==============================================
# EMAIL CONFIGURATION
# ==============================================

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ==============================================
