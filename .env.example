# Environment Configuration for Chronos AI Agent Builder Studio

# Application Settings
APP_NAME="Chronos AI Agent Builder Studio"
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Database Configuration
DATABASE_URL=postgresql+asyncpg://chronos_user:chronos_pass@localhost:5432/chronos_db

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# JWT Configuration
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Configuration
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# Security Settings
PASSWORD_MIN_LENGTH=8
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# Email Configuration (Optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# AI Provider API Keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
FIREWORKS_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# Voice and Speech Provider Keys
ELEVENLABS_API_KEY=
GOOGLE_CLOUD_API_KEY=
AZURE_SPEECH_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
DEEPGRAM_API_KEY=
ASSEMBLYAI_API_KEY=

# MCP Server Configuration (Optional)
MCP_SERVER_URL=
MCP_SERVER_API_KEY=
MCP_SERVER_TIMEOUT=30

# E2B Virtual Computer
E2B_API_KEY=

# File Storage Configuration
UPLOAD_MAX_SIZE=10485760  # 10MB in bytes
ALLOWED_FILE_TYPES=["txt", "pdf", "doc", "docx", "png", "jpg", "jpeg", "gif", "mp4", "avi", "mov"]

# WebSocket Configuration
WEBSOCKET_HEARTBEAT_INTERVAL=30
WEBSOCKET_PING_TIMEOUT=10

# Playwright MCP Server Configuration
PLAYWRIGHT_ENABLED=true
PLAYWRIGHT_SERVER_HOST=0.0.0.0
PLAYWRIGHT_SERVER_PORT=8080
PLAYWRIGHT_MAX_BROWSERS=5
PLAYWRIGHT_BROWSER_TIMEOUT=30000
PLAYWRIGHT_TASK_TIMEOUT=300000
PLAYWRIGHT_CONCURRENT_TASKS=10
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_BROWSER_TYPE=chromium
PLAYWRIGHT_USER_DATA_DIR=/data/playwright
PLAYWRIGHT_DOWNLOADS_DIR=/data/downloads
PLAYWRIGHT_SCREENSHOTS_DIR=/data/screenshots
PLAYWRIGHT_ARTIFACTS_RETENTION_HOURS=168
PLAYWRIGHT_PROXY_ENABLED=false
PLAYWRIGHT_PROXY_HOST=
PLAYWRIGHT_PROXY_PORT=
PLAYWRIGHT_PROXY_USERNAME=
PLAYWRIGHT_PROXY_PASSWORD=
PLAYWRIGHT_USER_AGENT=
PLAYWRIGHT_VIEWPORT_WIDTH=1920
PLAYWRIGHT_VIEWPORT_HEIGHT=1080
PLAYWRIGHT_HAR_ENABLED=true
PLAYWRIGHT_CDP_ENABLED=true
PLAYWRIGHT_NETWORK_INTERCEPTION=false
PLAYWRIGHT_ERROR_SCREENSHOT_ENABLED=true
PLAYWRIGHT_PERFORMANCE_MONITORING=false
PLAYWRIGHT_SECURITY_TOKEN=your-playwright-security-token-change-this
PLAYWRIGHT_AUTH_COOKIE_PREFIX=chronos_playwright
PLAYWRIGHT_STORAGE_BACKEND=local
PLAYWRIGHT_S3_BUCKET=
PLAYWRIGHT_S3_REGION=
PLAYWRIGHT_S3_ACCESS_KEY=
PLAYWRIGHT_S3_SECRET_KEY=
PLAYWRIGHT_NOTIFICATION_WEBHOOK_URL=

# Browser Pool Management
PLAYWRIGHT_BROWSER_POOL_SIZE=3
PLAYWRIGHT_BROWSER_IDLE_TIMEOUT=300
PLAYWRIGHT_BROWSER_WARMUP_ENABLED=true
PLAYWRIGHT_BROWSER_REUSE_ENABLED=true
PLAYWRIGHT_BROWSER_CLEANUP_INTERVAL=3600

# Network and Security
PLAYWRIGHT_ALLOWED_HOSTS=["*"]
PLAYWRIGHT_BLOCKED_HOSTS=["localhost", "127.0.0.1"]
PLAYWRIGHT_JAVASCRIPT_ENABLED=true
PLAYWRIGHT_PDF_GENERATION_ENABLED=true
PLAYWRIGHT_VIDEO_RECORDING_ENABLED=false
PLAYWRIGHT_VIDEO_RECORDING_DURATION=30

# Performance and Optimization
PLAYWRIGHT_CDP_PORT_START=9229
PLAYWRIGHT_CDP_PORT_END=9239
PLAYWRIGHT_MEMORY_LIMIT_MB=2048
PLAYWRIGHT_CPU_LIMIT_PERCENT=50
PLAYWRIGHT_DISK_SPACE_LIMIT_GB=10
PLAYWRIGHT_CACHE_ENABLED=true
PLAYWRIGHT_CACHE_SIZE_MB=512

# Development Settings
reload=true
workers=1
