# Database Configuration
DATABASE_URL=postgresql://chronos_user:chronos_pass@localhost:5432/chronos_db
POSTGRES_DB=chronos_db
POSTGRES_USER=chronos_user
POSTGRES_PASSWORD=chronos_pass

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# JWT Configuration
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development

# Frontend Configuration
VITE_API_URL=http://localhost:8000
VITE_APP_NAME=Chronos AI Agent Builder Studio

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Email Configuration (for future use)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-password

# External Services (for future use)
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key