# Environment Configuration for Chronos AI Agent Builder Studio

# Application Settings
APP_NAME="Chronos AI Agent Builder Studio"
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Database Configuration
DATABASE_URL=postgresql+asyncpg://chronos_user:chronos_pass@localhost:5432/chronos_db

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# JWT Configuration
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Configuration
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# Security Settings
PASSWORD_MIN_LENGTH=8
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# Email Configuration (Optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# AI Provider API Keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
FIREWORKS_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# Voice and Speech Provider Keys
ELEVENLABS_API_KEY=
GOOGLE_CLOUD_API_KEY=
AZURE_SPEECH_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
DEEPGRAM_API_KEY=
ASSEMBLYAI_API_KEY=

# MCP Server Configuration (Optional)
MCP_SERVER_URL=
MCP_SERVER_API_KEY=
MCP_SERVER_TIMEOUT=30

# E2B Virtual Computer
E2B_API_KEY=

# File Storage Configuration
UPLOAD_MAX_SIZE=10485760  # 10MB in bytes
ALLOWED_FILE_TYPES=["txt", "pdf", "doc", "docx", "png", "jpg", "jpeg", "gif", "mp4", "avi", "mov"]

# WebSocket Configuration
WEBSOCKET_HEARTBEAT_INTERVAL=30
WEBSOCKET_PING_TIMEOUT=10

# Development Settings
reload=true
workers=1
